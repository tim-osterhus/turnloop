# Turnloop model/runner config (live-reload)
#
# Both loop scripts source this file before each stage invocation, so changes
# here are picked up without restarting loops.
#
# Rules:
# - Use plain shell assignments: KEY=value
# - Keep values unquoted unless needed
# - Leave a value empty to use script defaults

# Shared defaults
RUNNER=codex
RUNNER_MODEL=gpt-5.2-codex

# Orchestrate loop: _start
START_RUNNER=gemini
START_MODEL=gemini-3.1-pro-preview
START_EFFORT=high
START_FALLBACK_RUNNER=codex
START_FALLBACK_MODEL=gpt-5.4

# Orchestrate loop: _check
CHECK_RUNNER=
CHECK_MODEL=gpt-5.4
CHECK_EFFORT=xhigh
CHECK_FALLBACK_RUNNER=codex
CHECK_FALLBACK_MODEL=gpt-5.4

# Orchestrate loop: _troubleshoot
TROUBLE_RUNNER=
TROUBLE_MODEL=gpt-5.3-codex-spark
TROUBLE_EFFORT=xhigh
TROUBLE_FALLBACK_RUNNER=codex
TROUBLE_FALLBACK_MODEL=gpt-5.3-codex
TROUBLE_AB_MODE=off
TROUBLE_MODEL_ALT=gpt-5.3-codex

# Orchestrate loop: _update
UPDATE_RUNNER=
UPDATE_MODEL=gpt-5.3-codex-spark
UPDATE_EFFORT=high
UPDATE_FALLBACK_RUNNER=codex
UPDATE_FALLBACK_MODEL=gpt-5.2-codex
UPDATE_AB_MODE=off
UPDATE_MODEL_ALT=gpt-5.2-codex

# Research loop: _research
RESEARCH_RUNNER=
RESEARCH_MODEL=gpt-5.4
RESEARCH_EFFORT=xhigh
RESEARCH_FALLBACK_RUNNER=codex
RESEARCH_FALLBACK_MODEL=gpt-5.4

# Research loop: _manage
MANAGE_RUNNER=gemini
MANAGE_MODEL=gemini-3-flash-preview
MANAGE_EFFORT=high
MANAGE_FALLBACK_RUNNER=codex
MANAGE_FALLBACK_MODEL=gpt-5.4

# Research loop: _mechanic
MECHANIC_RUNNER=
MECHANIC_MODEL=gpt-5.3-codex-spark
MECHANIC_EFFORT=xhigh
MECHANIC_FALLBACK_RUNNER=codex
MECHANIC_FALLBACK_MODEL=gpt-5.3-codex
MECHANIC_AB_MODE=off
MECHANIC_MODEL_ALT=gpt-5.3-codex
